{
  "name": "cvlite-resume-builder",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Privacy-first, offline, bilingual resume builder. React + TypeScript + Vite.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.mjs",
    "serve": "node server/index.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "legacy": "node server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "i18next": "^23.16.8",
    "idb-keyval": "^6.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^1.3.0"
  }
}
