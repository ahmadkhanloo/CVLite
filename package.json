{
  "name": "cvlite-resume-builder",
  "version": "0.2.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "description": "Privacy-first, offline, bilingual resume builder. React + TypeScript + Vite.",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/build-info.mjs",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.mjs",
    "serve": "node server/index.mjs",
    "typecheck": "tsc -p tsconfig.json",
    "deploy": "npm run build && wrangler deploy",
    "screenshot": "node scripts/screenshot.mjs",
    "gallery": "node scripts/gallery.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "i18next": "^23.16.8",
    "idb-keyval": "^6.2.5",
    "lucide-react": "^1.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.4.0",
    "react-router-dom": "^7.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^6.0.2",
    "puppeteer-core": "^25.1.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "esbuild": "0.28.1",
    "ws": "8.21.0"
  }
}
