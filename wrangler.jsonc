{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cvlite",
  "compatibility_date": "2026-06-17",
  "compatibility_flags": ["nodejs_compat"],
  // Worker serves static assets with SPA fallback.
  "main": "worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  }
}
